        % Button pushed function: btnCalculate
        function btnCalculateButtonPushed(app, event)
            A = [app.A11EditField.Value, app.A12EditField.Value, app.A13EditField.Value;
                app.A21EditField.Value, app.A22EditField.Value, app.A23EditField.Value;
                app.A31EditField.Value, app.A32EditField.Value, app.A33EditField.Value];

            B = [app.B11EditField.Value, app.B12EditField.Value, app.B13EditField.Value;
                app.B21EditField.Value, app.B22EditField.Value, app.B23EditField.Value;
                app.B31EditField.Value, app.B32EditField.Value, app.B33EditField.Value];

            eqn = strtrim(app.eqnFieldEditField.Value);

            if strcmp(eqn, 'inv(A)')
                if abs(det(A)) < 1e-10
                    app.resultAreaTextArea.Value = 'No inverse! det(A) = 0';
                else
                    R = inv(A);
                    txt = ['inv(A) =' newline sprintf('  %.4f  %.4f  %.4f\n', R(1,1),R(1,2),R(1,3)) sprintf('  %.4f  %.4f  %.4f\n', R(2,1),R(2,2),R(2,3)) sprintf('  %.4f  %.4f  %.4f\n', R(3,1),R(3,2),R(3,3))];
                    app.resultAreaTextArea.Value = txt;
                end

            elseif strcmp(eqn, 'inv(B)')
                if abs(det(B)) < 1e-10
                    app.resultAreaTextArea.Value = 'No inverse! det(B) = 0';
                else
                    R = inv(B);
                    txt = ['inv(B) =' newline sprintf('  %.4f  %.4f  %.4f\n', R(1,1),R(1,2),R(1,3)) sprintf('  %.4f  %.4f  %.4f\n', R(2,1),R(2,2),R(2,3)) sprintf('  %.4f  %.4f  %.4f\n', R(3,1),R(3,2),R(3,3))];
                    app.resultAreaTextArea.Value = txt;
                end

            elseif strcmp(eqn, 'inv(A*B)')
                C = A * B;
                if abs(det(C)) < 1e-10
                    app.resultAreaTextArea.Value = 'No inverse! det(A*B) = 0';
                else
                    R = inv(C);
                    txt = ['inv(A*B) =' newline sprintf('  %.4f  %.4f  %.4f\n', R(1,1),R(1,2),R(1,3)) sprintf('  %.4f  %.4f  %.4f\n', R(2,1),R(2,2),R(2,3)) sprintf('  %.4f  %.4f  %.4f\n', R(3,1),R(3,2),R(3,3))];
                    app.resultAreaTextArea.Value = txt;
                end

            elseif strcmp(eqn, 'det(A)')
                app.resultAreaTextArea.Value = sprintf('det(A) = %.6f', det(A));

            elseif strcmp(eqn, 'det(B)')
                app.resultAreaTextArea.Value = sprintf('det(B) = %.6f', det(B));

            elseif strcmp(eqn, 'det(A*B)')
                app.resultAreaTextArea.Value = sprintf('det(A*B) = %.6f', det(A*B));

            elseif strcmp(eqn, 'A*B')
                R = A*B;
                txt = ['A*B =' newline sprintf('  %.4f  %.4f  %.4f\n', R(1,1),R(1,2),R(1,3)) sprintf('  %.4f  %.4f  %.4f\n', R(2,1),R(2,2),R(2,3)) sprintf('  %.4f  %.4f  %.4f\n', R(3,1),R(3,2),R(3,3))];
                app.resultAreaTextArea.Value = txt;

            elseif strcmp(eqn, 'A+B')
                R = A+B;
                txt = ['A+B =' newline sprintf('  %.4f  %.4f  %.4f\n', R(1,1),R(1,2),R(1,3)) sprintf('  %.4f  %.4f  %.4f\n', R(2,1),R(2,2),R(2,3)) sprintf('  %.4f  %.4f  %.4f\n', R(3,1),R(3,2),R(3,3))];
                app.resultAreaTextArea.Value = txt;

            elseif strcmp(eqn, 'A-B')
                R = A-B;
                txt = ['A-B =' newline sprintf('  %.4f  %.4f  %.4f\n', R(1,1),R(1,2),R(1,3)) sprintf('  %.4f  %.4f  %.4f\n', R(2,1),R(2,2),R(2,3)) sprintf('  %.4f  %.4f  %.4f\n', R(3,1),R(3,2),R(3,3))];
                app.resultAreaTextArea.Value = txt;

            elseif strcmp(eqn, 'A^2')
                R = A^2;
                txt = ['A^2 =' newline sprintf('  %.4f  %.4f  %.4f\n', R(1,1),R(1,2),R(1,3)) sprintf('  %.4f  %.4f  %.4f\n', R(2,1),R(2,2),R(2,3)) sprintf('  %.4f  %.4f  %.4f\n', R(3,1),R(3,2),R(3,3))];
                app.resultAreaTextArea.Value = txt;

            elseif strcmp(eqn, 'A^3')
                R = A^3;
                txt = ['A^3 =' newline sprintf('  %.4f  %.4f  %.4f\n', R(1,1),R(1,2),R(1,3)) sprintf('  %.4f  %.4f  %.4f\n', R(2,1),R(2,2),R(2,3)) sprintf('  %.4f  %.4f  %.4f\n', R(3,1),R(3,2),R(3,3))];
                app.resultAreaTextArea.Value = txt;

            elseif strcmp(eqn, 'trace(A)')
                app.resultAreaTextArea.Value = sprintf('trace(A) = %.6f', trace(A));

            elseif strcmp(eqn, 'A*inv(B)')
                if abs(det(B)) < 1e-10
                    app.resultAreaTextArea.Value = 'No inverse! det(B) = 0';
                else
                    R = A*inv(B);
                    txt = ['A*inv(B) =' newline sprintf('  %.4f  %.4f  %.4f\n', R(1,1),R(1,2),R(1,3)) sprintf('  %.4f  %.4f  %.4f\n', R(2,1),R(2,2),R(2,3)) sprintf('  %.4f  %.4f  %.4f\n', R(3,1),R(3,2),R(3,3))];
                    app.resultAreaTextArea.Value = txt;
                end

            else
                app.resultAreaTextArea.Value = ['Unknown! Try:' newline ...
                    'inv(A)   inv(B)   inv(A*B)' newline ...
                    'det(A)   det(B)   det(A*B)' newline ...
                    'A*B      A+B      A-B' newline ...
                    'A^2      A^3      trace(A)' newline ...
                    'A*inv(B)'];
            end
        end
    end

